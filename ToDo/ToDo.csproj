<Project Sdk="Uno.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net10.0-android;net10.0-desktop</TargetFrameworks>

        <OutputType>Exe</OutputType>
        <UnoSingleProject>true</UnoSingleProject>

        <ApplicationTitle>ToDo</ApplicationTitle>
        <Product>ToDo</Product>
        <ApplicationId>com.christopheraliprantis.todo</ApplicationId>

        <ApplicationDisplayVersion>3.0.1</ApplicationDisplayVersion>
        <ApplicationVersion>3.0.1</ApplicationVersion>
        <Version>3.0.1</Version>
        <ApplicationPublisher>Christopher Aliprantis</ApplicationPublisher>
        <Description>ToDo, your ultimate time management app</Description>
        <authors>Christopher Aliprantis</authors>

        <UnoDisableHotDesign>true</UnoDisableHotDesign>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

        <!-- Global Build Fixes -->
        <SkipResourcesGenerator>true</SkipResourcesGenerator>
        <UnoDeployOptionalResources>false</UnoDeployOptionalResources>
        <Platforms>AnyCPU;x64</Platforms>
    </PropertyGroup>

    <!-- DESKTOP ONLY: Fixes Original Filename and Metadata -->
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <ApplicationIcon>Assets\Icons\todoico.ico</ApplicationIcon>
        <UnoIcon>Assets\Icons\todoico.ico</UnoIcon>
        <AssemblyName>ToDo</AssemblyName>
        <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
        <TargetName>ToDo</TargetName>
        <AssemblyTitle>ToDo</AssemblyTitle>
        <!-- This is what was causing Android errors; now it's isolated -->
        <UseAppHost>true</UseAppHost>
    </PropertyGroup>
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-android'">
        <AndroidApplication>true</AndroidApplication>
        <AndroidIcon>appicon</AndroidIcon>
        <UseAppHost>false</UseAppHost>
    </PropertyGroup>
    <Import Project="keystore.targets" />
    <!-- for people that downloaded this from github, this is a file where I had keystore properties, I .gitignored it, because it has private info.-->
    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        <None Remove="WinRTapis.dll" />
    </ItemGroup>

    <PropertyGroup>
        <UnoFeatures>
            CSharpMarkup;
            Lottie;
            Hosting;
            Toolkit;
            MVUX;
            Configuration;
            Localization;
            ThemeService;
            SkiaRenderer;
            Svg;
        </UnoFeatures>
    </PropertyGroup>

    <ItemGroup>
      <None Remove="Assets\Icons\todosvg.svg" />
      <None Remove="Assets\reload" />
    </ItemGroup>


    <ItemGroup>
        <Folder Include="Platforms\Android\Resources\mipmap-mdpi" />
        <Folder Include="Platforms\Android\Resources\mipmap-hdpi" />
        <Folder Include="Platforms\Android\Resources\mipmap-xhdpi" />
        <Folder Include="Platforms\Android\Resources\mipmap-xxhdpi" />
        <Folder Include="Platforms\Android\Resources\mipmap-xxxhdpi" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-android'">
        <None Update="Assets\DLLs\WinRTapis.dll">
            <CopyToOutputDirectory>Do Not Copy</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        
        <None Remove="Platforms\Desktop\WinRTapis.dll" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        <Content Update="Assets\DLLs\WinRTapis.dll">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <!-- 1. Stop generating PDB files completely in Release mode -->
    <!-- 1. Ensure symbols generate normally during build so Uno doesn't crash -->
    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <DebugType>portable</DebugType>
        <DebugSymbols>true</DebugSymbols>
    </PropertyGroup>

    <!-- 2. Cleanly delete both PDBs and Uprimarkers from the final output folder -->
    <Target Name="CleanReleaseOutput" AfterTargets="Publish">
        <ItemGroup>
            <FilesToRemove Include="$(PublishDir)**\*.uprimarker" />
            <FilesToRemove Include="$(PublishDir)**\*.pdb" />
        </ItemGroup>
        <Delete Files="@(FilesToRemove)" ContinueOnError="true" />
        <Message Text="Successfully stripped all .pdb and .uprimarker files from the publish directory!" Importance="high" />
    </Target>
    <ItemGroup>
      <Content Update="Assets\reload">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </Content>
    </ItemGroup>
    <ItemGroup>
        <CopyToOutputDirectory Include="Assets\Splash\splash_screen.svg" />
    </ItemGroup>
    <ItemGroup>
      <UnoImage Remove="Assets\Splash\splash_screen.svg" />
    </ItemGroup>
    <ItemGroup>
      <UnoSplashScreen Include="Assets\Splash\splash_screen.svg">
        <IsDefaultItem>true</IsDefaultItem>
        <Color>$(UnoSplashScreenColor)</Color>
        <BaseSize>$(UnoSplashScreenBaseSize)</BaseSize>
      </UnoSplashScreen>
    </ItemGroup>
    <ItemGroup>
      <Content Include="Assets\Splash\splash_screen" />
      <CopyToOutputDirectory Include="Assets\Splash\splash_screen" />
    </ItemGroup>

</Project>