<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="com.christopheraliprantis.todo"
          android:versionCode="1"
          android:versionName="1.0">

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Needed for alarms to survive reboot (optional but recommended) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:supportsRtl="true"
        android:label="ToDo"
        android:theme="@style/UnoAppTheme"
        android:icon="@mipmap/appicon">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustPan">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification trigger -->
        <receiver
          android:name="ToDo.Droid.AndroidNotificationService+NotificationReceiver"
          android:enabled="true"
          android:exported="false" />

    </application>
</manifest>
